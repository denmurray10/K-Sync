# Backblaze B2 Credentials
# Get these from your Backblaze Account Settings / App Keys
B2_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your_bucket_name

# The endpoint/download URL (e.g., https://f000.backblazeb2.com)
# This is used for generating public links to your song files.
B2_DOWNLOAD_URL=https://f000.backblazeb2.com

# Cloudinary (required for voiceover/audio cloud storage)
# Get these from Cloudinary Dashboard → API Environment Variables
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Radio.co live stream integration
# Get the station ID from your Radio.co dashboard URL and the listen URL from Listen Links.
RADIOCO_ENABLED=false
RADIOCO_STATION_ID=your_station_id
RADIOCO_LISTEN_URL=https://streaming.radio.co/your_station/listen
