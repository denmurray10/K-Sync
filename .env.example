# Backblaze B2 Credentials
# Get these from your Backblaze Account Settings / App Keys
B2_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your_bucket_name

# The endpoint/download URL (e.g., https://f000.backblazeb2.com)
# This is used for generating public links to your song files.
B2_DOWNLOAD_URL=https://f000.backblazeb2.com

# Cloudinary (required for voiceover/audio cloud storage)
# Get these from Cloudinary Dashboard → API Environment Variables
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Core Django
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace_with_long_random_secret
DJANGO_ALLOWED_HOSTS=kbeatsradio.co.uk,www.kbeatsradio.co.uk
CSRF_TRUSTED_ORIGINS=https://kbeatsradio.co.uk,https://www.kbeatsradio.co.uk

# Database (recommended for production)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# HTTPS / cookie security (recommended true in production)
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# Streaming toggles
AUDIO_STREAM_USE_CLOUDINARY_FETCH=false
AUDIO_STREAM_CLOUDINARY_TRANSFORM=q_auto:eco,br_96k,f_mp3
IMAGE_STREAM_USE_CLOUDINARY_FETCH=true
IMAGE_STREAM_CLOUDINARY_TRANSFORM=f_auto,q_auto

# Social / analytics (optional)
GOOGLE_TAG_MANAGER_ID=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PIXEL_ID=

# AI / content integrations (optional unless used by enabled features)
DEEPSEEK_API_KEY=
INWORLD_API_KEY=
GETIMG_API_KEY=
PEXELS_API_KEY=
SERPER_API_KEY=
