# Backblaze B2 Credentials
# Get these from your Backblaze Account Settings / App Keys
B2_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your_bucket_name

# The endpoint/download URL (e.g., https://f000.backblazeb2.com)
# This is used for generating public links to your song files.
B2_DOWNLOAD_URL=https://f000.backblazeb2.com

# Cloudinary (required for voiceover/audio cloud storage)
# Get these from Cloudinary Dashboard → API Environment Variables
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Analytics and tag management
# Google Tag Manager container ID, e.g. GTM-XXXXXXX
GOOGLE_TAG_MANAGER_ID=
# Microsoft Clarity project ID from Clarity Settings > Setup
CLARITY_PROJECT_ID=
# Set to false to suppress GTM, Clarity, and similar third-party scripts
ENABLE_THIRD_PARTY_TRACKING=true

# Radio.co live stream integration
# Get the station ID from your Radio.co dashboard URL and the listen URL from Listen Links.
RADIOCO_ENABLED=false
RADIOCO_STATION_ID=your_station_id
RADIOCO_LISTEN_URL=https://streaming.radio.co/your_station/listen
# Requests widget: create one in Radio.co under Requests > Widgets, then paste either the widget ID
# (for example w123abc456) or the full embed script URL.
RADIOCO_REQUEST_WIDGET_ID=
RADIOCO_REQUEST_WIDGET_SRC=

# Facebook Page posting
# Use a Page access token with pages_manage_posts and pages_read_engagement.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_POST_ENABLED=true
FACEBOOK_POST_ON_CREATE_ENABLED=false
FACEBOOK_POST_INTERVAL_MINUTES=60
FACEBOOK_POST_QUEUE_START_DATE=2026-03-26
